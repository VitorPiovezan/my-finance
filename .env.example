# Copie para `.env` (não versionado). Variáveis VITE_* entram no bundle do front
# — qualquer pessoa com DevTools consegue ler. Use as observações abaixo pra
# proteger o que for sensível.

# Google Cloud Console → OAuth 2.0 Client ID (aplicação Web). Tratado como
# credencial pública; restrinja URIs autorizadas no console.
VITE_GOOGLE_OAUTH_CLIENT_ID=

# ID da pasta raiz no Google Drive (está na URL ao abrir a pasta).
VITE_DRIVE_FINANCE_ROOT_FOLDER_ID=

# PIN de acesso: aqui vai o HASH SHA-256 (hex minúsculo, 64 chars) do PIN,
# NÃO o PIN em texto puro. Exemplos de como gerar:
#   echo -n "1234" | sha256sum
#   node -e "console.log(require('crypto').createHash('sha256').update('1234').digest('hex'))"
# Deixe vazio se não quiser exigir PIN (app fica aberto).
VITE_APP_ACCESS_PIN_SHA256=

# Categorização automática por IA (Google Gemini). Variáveis VITE_* entram no bundle!
# Recomendado: deixe em branco aqui e configure a chave direto no app (tela
# "Configurar IA") — ela fica só no localStorage deste navegador.
# Gere uma chave em https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
# Modelo padrão (ex.: gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash).
VITE_GEMINI_MODEL=gemini-2.5-flash

# Caminho base em build (usado pelo GitHub Pages). Normalmente não precisa
# mexer local — o workflow de deploy seta pra /my-finance/ automaticamente.
# VITE_BASE_PATH=/my-finance/
