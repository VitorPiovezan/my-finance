rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Doc ID = e-mail em minúsculas (ver driveUserConfig.ts). Leitura pública para o login com e-mail.
    // Escrita só com Firebase Auth e o token.email igual ao ID do documento (cadastro via link mágico).
    match /drive_user_configs/{email} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.token.email == email;
    }
  }
}
